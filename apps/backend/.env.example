# Copy this file to .env and fill in your values
# This file is the source of truth for the backend environment.

# App
NODE_ENV=development
PORT=9940

# Database
DB_HOST=localhost
DB_PORT=3307          # Use 3307 locally to avoid conflicts; 3306 in Docker network
DB_USER=unibooking
DB_PASSWORD=secret
DB_NAME=unibooking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380       # Use 6380 locally to avoid conflicts; 6379 in Docker network
REDIS_PASSWORD=redissecret

# JWT — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_CUSTOMER_EXPIRES_IN=24h

# AES-256 encryption key — must be exactly 32 characters
AES_SECRET_KEY=change_this_32_char_key_for_prod!

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_smtp_password
SMTP_FROM="Unibooking <noreply@yourdomain.com>"

# App URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Mayar.id — 'production' uses api.mayar.id, 'testing' uses sandbox api.mayar.club
MAYAR_ENVIRONMENT=production
# Mayar.id webhook signature secret
MAYAR_WEBHOOK_SECRET=your_mayar_webhook_secret

# Docker compose only (not read by the app)
MYSQL_ROOT_PASSWORD=rootsecret
DEV_MYSQL_PORT=3307
DEV_REDIS_PORT=6380
