# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=unibooking
DB_PASSWORD=secret
DB_NAME=unibooking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redissecret

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_CUSTOMER_EXPIRES_IN=24h

# AES Encryption
AES_SECRET_KEY=32_char_hex_key_here_change_this!

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=smtp_password
SMTP_FROM="Unibooking <noreply@example.com>"

# App URL (for email links)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Mayar webhook secret
MAYAR_WEBHOOK_SECRET=your_mayar_webhook_secret
